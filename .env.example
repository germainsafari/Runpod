# RunPod
RUNPOD_API_KEY=your_runpod_api_key_here
RUNPOD_ENDPOINT_ID=your_endpoint_id_here

# Hugging Face (required to build the Docker image and access FLUX.1-dev)
HF_TOKEN=your_huggingface_token_here

# Docker Hub username for pushing the worker image
DOCKER_USERNAME=your_dockerhub_username

# Backend only — comma-separated frontend URLs for CORS (set after Vercel deploy)
FRONTEND_URL=https://your-app.vercel.app
